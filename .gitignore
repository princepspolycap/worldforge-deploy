# Environment variables and local credentials
.env
.env.*
.env.local
.env.*.local
**/.env
**/.env.*
!.env.example
!**/.env.example

# Maintainer-only working notes (deployment names, quota numbers, demo-day
# logistics, draft blogs). Never committed - this is an open-source repo.
submission/private/

# API keys and secrets
**/secrets/
**/config/secrets.*
**/.secrets
*.pem
*.key
*.pfx

# Dependencies
node_modules/
venv/
env/
.venv/
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
.history/
*.swp
*.swo
*~
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# TypeScript / JavaScript
*.tsbuildinfo
.npm
.eslintcache

# Testing
.pytest_cache/
.coverage
htmlcov/
.nyc_output
submission/docs/llm_smoke_test_results*.json
submission/docs/*smoke*results*.json
submission/docs/*eval*results*.json
submission/evals/results/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Azure
.azure/

# Local demo state, replay exports, and generated media
*.tmp
*.temp
.cache/
submission/state/*.json
submission/state/slots/
submission/replay/*.json
submission/replay/*.jsonl
submission/replay/*.log
# Foundry IQ sync artifact: regenerable from submission/knowledge/ via
# tools/iq_sync.py, so it is a build output, not source.
submission/knowledge/_index/
submission/ui/assets/local/
# The assembled lore intro film (film.voiced.mp4, ~50MB) ships committed so a
# fresh `git clone` plays the cinematic with no setup; the tracked film.png
# still is the graceful fallback. Superseded per-scene clips (old_v2/) and raw
# render frames (frames/) stay local-only.
submission/ui/assets/generated/lore/video/*
!submission/ui/assets/generated/lore/video/film.voiced.mp4
# Cast idle clips (Veo image-to-video) are heavy + local-only, like the lore
# film; the committed PNG sprites are the baseline and the UI upgrades to a clip
# when one is present. Keep a placeholder README tracked so the path is visible.
submission/ui/assets/generated/characters/video/*.mp4
submission/ui/assets/generated/characters/_v1_prewakanda/

# Build outputs
dist/
build/
out/

# Package files
*.zip
*.tar.gz
*.rar

# Keep structure
!.gitkeep
