# Build context = submission/. This file is the primary leak guard for the
# container image: secrets, prior-run state, and maintainer notes must NEVER be
# uploaded to the registry build or baked into a layer.

# --- Secrets (never ship) ---
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
**/secrets/
**/.secrets

# --- Maintainer-only / private notes ---
private/

# --- Prior-run game state and learned memory (start the deployed app clean) ---
state/state.json
state/state.*.json
state/memory.json
state/memory.*.json
state/profile_cache.json
state/usage.json
state/slots/
replay/*
!replay/.gitkeep

# --- Caches / build cruft ---
__pycache__/
*.py[cod]
*.so
.pytest_cache/
.coverage
htmlcov/
.venv/
venv/
env/
.DS_Store
*.log
*.tmp
*.temp
.cache/

# --- Deploy tooling itself (not needed inside the image) ---
deploy/
Dockerfile
.dockerignore

# --- Locally generated art that is gitignored / not redistributable ---
ui/assets/local/

# --- Local-only narration/lore VIDEO (~240M, mostly gitignored). A fresh clone
#     never has these; the intro UI fetch-probes each clip and falls back to the
#     tracked PNG still on 404, so excluding them keeps the image lean. The ONE
#     exception is the tracked intro film (film.voiced.mp4, ~52M, committed to
#     git) which the opening scene plays full-bleed - it must ship in the image
#     so the deployed app opens with the film, not the poster fallback. Tracked
#     .mp3 narration and .png stills are intentionally kept too. ---
ui/assets/generated/**/*.mp4
ui/assets/generated/lore/video/*
# Keep the one committed intro film so the deployed app plays it.
!ui/assets/generated/lore/video/film.voiced.mp4

# --- Unused alternate art. The cast/party worker portraits
#     (generated/characters/*.png) ARE referenced by the floating cast + worker
#     cards (story.js castPortraitSrc), so they MUST ship - keep only the 7
#     top-level PNGs and drop the heavy alt-art (_v1_prewakanda/) + motion
#     (characters/video/) subdirs and the pre-versioned lore stills. ---
ui/assets/generated/characters/_v1_prewakanda/
ui/assets/generated/characters/video/
ui/assets/generated/lore/_prev/
