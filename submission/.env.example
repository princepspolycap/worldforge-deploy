# ---------------------------------------------------------------------------
# Microsoft Foundry - reasoning core (REQUIRED for live demo)
# ---------------------------------------------------------------------------
# Auth strategy (in priority order):
#   1. Azure AD via DefaultAzureCredential (recommended). Just run `az login`
#      locally, or set Managed Identity / Service Principal env vars in CI.
#   2. FOUNDRY_API_KEY fallback for quick local dev.
# Never commit real values. This file is the public template; the gitignored
# submission/.env holds your secrets.

# Foundry resource endpoint - the v1 OpenAI-compatible inference URL of your
# Azure AI Foundry project. Example shape (substitute your own resource):
#   https://<your-foundry-resource>.services.ai.azure.com/openai/v1/
FOUNDRY_BASE_URL=
FOUNDRY_API_KEY=

# Azure subscription scope (used by SDK when auth=AAD)
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_RESOURCE_GROUP=
AZURE_AI_PROJECT_NAME=

# ---------------------------------------------------------------------------
# Agent -> deployment mapping
# ---------------------------------------------------------------------------
# Set these to the deployment names provisioned in your Foundry project.
# Defaults shown are placeholders; replace with your own deployment names.
NARRATOR_MODEL=
STRATEGIST_MODEL=
DESIGNER_MODEL=
MARKETER_MODEL=
OPS_MODEL=
NPC_FAST_MODEL=

# Reliability net: a high-quota deployment retried automatically when a primary
# model returns a 429 (rate limit) or errors mid-run. Must be a deployment that
# exists on your endpoint with quota headroom. Leave blank to disable fallback.
FOUNDRY_FALLBACK_MODEL=

# ---------------------------------------------------------------------------
# Voice / narration - real Azure neural TTS (optional)
# ---------------------------------------------------------------------------
# Voice-model upgrade chain, newest first, comma-separated. The server tries
# each in order and auto-detects the right API shape per model:
#   - gpt-audio-1.5 / MAI-Voice-1  -> chat-completions audio API (newest voices)
#   - gpt-4o-mini-tts / tts-1      -> /audio/speech API (older fallback)
# The browser keeps its own speechSynthesis fallback, so leaving these blank
# still gives narration after a fresh git clone.
TTS_ENDPOINT=
TTS_DEPLOYMENTS=gpt-audio-1.5,gpt-4o-mini-tts
# Legacy single-deployment key, used only when TTS_DEPLOYMENTS is unset.
TTS_DEPLOYMENT=gpt-4o-mini-tts
TTS_API_KEY=
TTS_VOICE=onyx
TTS_API_VERSION=2025-03-01-preview

# ---------------------------------------------------------------------------
# Image generation - Microsoft MAI image models (optional, pluggable)
# ---------------------------------------------------------------------------
# Default: MAI-Image-2e (Microsoft's efficient image model - highest RPM quota
# of the MAI family, ~4x more efficient than MAI-Image-2; quality is good, not
# best-in-class, which is a fine trade for generated game art).
# Anyone forking this repo can plug in their own deployment to test:
#   1. Deploy in a supported region (East US, West Central US, West US,
#      West Europe, Sweden Central, South India, UAE North):
#        az cognitiveservices account deployment create \
#          -n <account> -g <rg> --deployment-name MAI-Image-2e \
#          --model-name MAI-Image-2e --model-version 2026-04-09 \
#          --model-format Microsoft --sku-name GlobalStandard --sku-capacity 1
#   2. Fill the three values below. The API route is:
#        POST {IMAGE_ENDPOINT}/mai/v1/images/generations
#      with JSON body {"model": IMAGE_DEPLOYMENT, "prompt": ..., "width": 1024,
#      "height": 1024} and an `api-key` header. Output is always PNG.
# Swappable: MAI-Image-2.5 / MAI-Image-2.5-Flash (adds image edits), or
# gpt-image-1.5 (different API route). Not on the critical reasoning path;
# leave blank and the game ships geometric-first art.
IMAGE_ENDPOINT=
IMAGE_DEPLOYMENT=MAI-Image-2e
IMAGE_API_KEY=

# ---------------------------------------------------------------------------
# Demo controls
# ---------------------------------------------------------------------------
# simulation = no Azure calls, mock agent outputs (default; safe for CI)
# live       = real Foundry calls (requires auth above)
DEMO_MODE=simulation

# Optional tool integrations - safe to leave disabled.
ENABLE_POLY_BACKEND=false
POLY_BACKEND_URL=
