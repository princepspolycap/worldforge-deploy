# ---------------------------------------------------------------------------
# Microsoft Foundry - reasoning core (REQUIRED for live demo)
# ---------------------------------------------------------------------------
# Auth strategy (in priority order):
#   1. Azure AD via DefaultAzureCredential (recommended). Just run `az login`
#      locally, or set Managed Identity / Service Principal env vars in CI.
#   2. FOUNDRY_API_KEY fallback for quick local dev.
# Never commit real values. This file is the public template; the gitignored
# submission/.env holds your secrets.

# Foundry resource endpoint - the v1 OpenAI-compatible inference URL of your
# Azure AI Foundry project. Example shape (substitute your own resource):
#   https://<your-foundry-resource>.services.ai.azure.com/openai/v1/
FOUNDRY_BASE_URL=
FOUNDRY_API_KEY=

# Foundry PROJECT endpoint (preferred path) - the "Foundry new" project URL:
#   https://<resource>.services.ai.azure.com/api/projects/<project-name>
# When set, Agent Framework workers run through FoundryChatClient on the
# project Responses endpoint (agent-framework-foundry) with AAD auth.
# Requires the signed-in identity to hold the Azure AI User / Azure AI
# Developer role on the Foundry resource. Leave blank to use the
# FOUNDRY_BASE_URL compatibility path above - everything still runs.
FOUNDRY_PROJECT_ENDPOINT=

# Foundry IQ knowledge base name (optional). When set together with
# FOUNDRY_PROJECT_ENDPOINT, worker recall queries the real IQ knowledge base
# (permission-aware, cited retrieval). Blank = local knowledge/ fallback,
# which keeps a keyless clone fully playable.
FOUNDRY_IQ_KNOWLEDGE_BASE=

# Foundry Agent Service memory store name (optional). Memory is separate from
# IQ: IQ answers from stable curated knowledge; memory holds what the agents
# LEARN from the player - CEO gate decisions (procedural), founder profile
# (user_profile), and chapter summaries (chat_summary). Blank = the local
# ledger at state/memory.json carries the same learning loop, fully forkable.
FOUNDRY_MEMORY_STORE=

# Azure subscription scope (used by SDK when auth=AAD)
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_RESOURCE_GROUP=
AZURE_AI_PROJECT_NAME=

# ---------------------------------------------------------------------------
# Agent -> deployment mapping
# ---------------------------------------------------------------------------
# Set these to the deployment names provisioned in your Foundry project.
# Defaults shown are placeholders; replace with your own deployment names.
# Cost policy:
# - UI/copy/layout iteration: keep DEMO_MODE=simulation whenever possible.
# - Normal play: route through a local agent by default when configured.
# - Cloud fallback/testing: point every role below at the smallest/cheapest
#   Foundry deployment you have quota for.
# - Final demo pass: only upgrade the visible reasoning roles that need it
#   (usually NARRATOR_MODEL / STRATEGIST_MODEL / DESIGNER_MODEL).
# See docs/model_cost_policy.md.
NARRATOR_MODEL=
STRATEGIST_MODEL=
DESIGNER_MODEL=
MARKETER_MODEL=
OPS_MODEL=
NPC_FAST_MODEL=

# Reliability net: a high-quota deployment retried automatically when a primary
# model returns a 429 (rate limit) or errors mid-run. Must be a deployment that
# exists on your endpoint with quota headroom. Leave blank to disable fallback.
FOUNDRY_FALLBACK_MODEL=

# ---------------------------------------------------------------------------
# Toolboxes in Foundry (optional) - one managed MCP endpoint for every tool
# ---------------------------------------------------------------------------
# When set, the local toolbox (tools/toolbox.py) passes tools/list and
# tools/call through to your Foundry Toolbox over MCP. Leave blank and the
# same catalog runs on the local implementations - a keyless clone still plays.
TOOLBOX_URL=
TOOLBOX_API_KEY=

# ---------------------------------------------------------------------------
# Voice / narration - real Azure neural TTS (optional)
# ---------------------------------------------------------------------------
# When set, the server synthesizes narration with Azure OpenAI-style speech
# deployments. Use TTS_DEPLOYMENTS to try newer audio deployments first, then
# fall back to the stable TTS_DEPLOYMENT. The browser keeps its own
# speechSynthesis fallback, so leaving these blank still gives narration.
TTS_ENDPOINT=
TTS_DEPLOYMENTS=
TTS_DEPLOYMENT=gpt-4o-mini-tts
TTS_API_KEY=
TTS_VOICE=onyx
TTS_API_VERSION=2025-03-01-preview

# ---------------------------------------------------------------------------
# Image generation - latest Microsoft MAI image model (optional)
# ---------------------------------------------------------------------------
# e.g. MAI-Image-2.5-Flash. Used for optional artifact visuals (org charts,
# hero mockups). Not on the critical reasoning path; safe to leave blank.
IMAGE_ENDPOINT=
IMAGE_DEPLOYMENT=MAI-Image-2.5-Flash
IMAGE_API_KEY=

# Optional image generation deployment (separate Azure OpenAI URL)
IMAGE_DEPLOYMENT_URL=
IMAGE_API_KEY=
IMAGE_MODEL=

# ---------------------------------------------------------------------------
# Demo controls
# ---------------------------------------------------------------------------
# simulation = no Azure calls, mock agent outputs (default; safe for CI)
# live       = real Foundry calls (requires auth above)
DEMO_MODE=simulation

# Optional tool integrations - safe to leave disabled.
ENABLE_POLY_BACKEND=false
POLY_BACKEND_URL=

# Web search note: the standalone Bing Search API was RETIRED (Aug 2025); its
# successor (Grounding with Bing Search, a paid Foundry Agents tool) is NOT
# required here. Company knowledge comes from Foundry IQ / local playbooks,
# and company-URL mapping uses the built-in stdlib scraper (SSRF-guarded).
# If you want live web search, expose it through your Foundry Toolbox
# (TOOLBOX_URL above) - the local catalog needs no paid search API.
